{
  "manifest_version": 3,
  "name": "SessionMaster \u00b7 \u4f1a\u8bdd\u5927\u5e08",
  "version": "1.6.9",
  "author": "BenSon.Album (chinasir@qq.com)",
  "description": "\u7a81\u7834\u7f51\u7ad9\u5355\u8bbe\u5907\u767b\u5f55\u9650\u5236 \u2014\u2014 \u8de8\u6d4f\u89c8\u5668 Cookie \u540c\u6b65 + \u62e6\u622a\u8e22\u4eba\u8bf7\u6c42",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "icons": {
    "128": "icons/icon128.svg"
  },
  "permissions": [
    "cookies",
    "storage",
    "unlimitedStorage",
    "alarms",
    "system.cpu",
    "system.memory",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "notifications",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SessionMaster \u00b7 \u4f1a\u8bdd\u5927\u5e08",
    "default_icon": {
      "128": "icons/icon128.svg"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "help/*",
        "server/*",
        "deploy/*",
        "changelog.json",
        "blocking_rules.json",
        "blocking_rules_db.json",
        "storage_presets.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}